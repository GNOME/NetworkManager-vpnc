#: ../src/nm-vpnc-service.c:204
#, c-format
msgid "property “%s” invalid or not supported"
msgstr "«%s» қасиеті жарамсыз немесе қолданылмайды"

#: ../src/nm-vpnc-service.c:219
#, c-format
msgid "property “%s” contains a newline character"
msgstr "«%s» қасиетінде жаңа жол таңбасы бар"

#: ../src/nm-vpnc-service.c:231
#, c-format
msgid "property “%s” file path “%s” is not absolute or does not exist"
msgstr "«%s» қасиетінің «%s» файл жолы абсолютті емес немесе жоқ"

#: ../src/nm-vpnc-service.c:244
#, c-format
msgid "invalid integer property “%s” or out of range [%d -> %d]"
msgstr "«%s» бүтін сан қасиеті жарамсыз немесе ауқымнан тыс [%d -> %d]"

#: ../src/nm-vpnc-service.c:254
#, c-format
msgid "invalid boolean property “%s” (not yes or no)"
msgstr "«%s» жарамсыз логикалық қасиеті (иә немесе жоқ емес)"

#: ../src/nm-vpnc-service.c:261
#, c-format
msgid "unhandled property “%s” type %d"
msgstr "өңделмеген «%s» қасиеті, түрі %d"

#: ../src/nm-vpnc-service.c:278
msgid "No VPN configuration options."
msgstr "VPN конфигурациясының опциялары жоқ."

#: ../src/nm-vpnc-service.c:304
msgid "No VPN secrets!"
msgstr "VPN құпиялары жоқ!"

#: ../src/nm-vpnc-service.c:649
msgid "Could not find vpnc binary."
msgstr "vpnc бинарлық файлы табылмады."

#: ../src/nm-vpnc-service.c:767
#, c-format
msgid "Config option “%s” invalid or unknown."
msgstr "«%s» конфигурация опциясы жарамсыз немесе белгісіз."

#: ../src/nm-vpnc-service.c:802
#, c-format
msgid "Config option “%s” not an integer."
msgstr "«%s» конфигурация опциясы бүтін сан емес."

#: ../src/nm-vpnc-service.c:990
msgid "vpnc does not support interactive requests"
msgstr "vpnc интерактивті сұранымдарды қолдамайды"

#: ../src/nm-vpnc-service.c:1014
msgid "Could not use new secrets as interactive mode is disabled."
msgstr "Интерактивті режим сөндірілгендіктен, жаңа құпияларды пайдалану мүмкін емес."

#: ../src/nm-vpnc-service.c:1023 ../src/nm-vpnc-service.c:1097
msgid "Could not process the request because the VPN connection settings were invalid."
msgstr "VPN қосылымының баптаулары жарамсыз болғандықтан, сұранымды өңдеу мүмкін болмады."

#: ../src/nm-vpnc-service.c:1031
msgid "Could not process the request because no pending authentication is required."
msgstr "Күтіп тұрған аутентификация талап етілмегендіктен, сұранымды өңдеу мүмкін болмады."

#: ../src/nm-vpnc-service.c:1042
#, c-format
msgid "Could not process the request because the requested info “%s” was not provided."
msgstr "Сұралған «%s» ақпараты берілмегендіктен, сұранымды өңдеу мүмкін болмады."

#: ../src/nm-vpnc-service.c:1240
msgid "Don’t quit when VPN connection terminates"
msgstr "VPN қосылымы аяқталған кезде шықпау"

#: ../src/nm-vpnc-service.c:1241
msgid "Enable verbose debug logging (may expose passwords)"
msgstr "Толық дебаг журналын іске қосу (парольдерді ашуы мүмкін)"

#: ../src/nm-vpnc-service.c:1242
msgid "D-Bus name to use for this instance"
msgstr "Бұл инстанция үшін қолданылатын D-Bus атауы"

#: ../src/nm-vpnc-service.c:1265
msgid "nm-vpnc-service provides integrated Cisco Legacy IPsec VPN capability to NetworkManager."
msgstr ""
"nm-vpnc-service бағдарламасы NetworkManager үшін интеграцияланған Cisco Legacy IPsec VPN мүмкіндігін "
"ұсынады."

#: ../shared/nm-utils/nm-shared-utils.c:264
#, c-format
msgid "object class '%s' has no property named '%s'"
msgstr "'%s' объект класында '%s' атты қасиет жоқ"

#: ../shared/nm-utils/nm-shared-utils.c:271
#, c-format
msgid "property '%s' of object class '%s' is not writable"
msgstr "'%s' объект класының '%s' қасиетіне жазу мүмкін емес"

#: ../shared/nm-utils/nm-shared-utils.c:278
#, c-format
msgid "construct property \"%s\" for object '%s' can't be set after construction"
msgstr "'%s' объектісі үшін «%s» құрастыру қасиетін құрастырудан кейін орнату мүмкін емес"

#: ../shared/nm-utils/nm-shared-utils.c:286
#, c-format
msgid "'%s::%s' is not a valid property name; '%s' is not a GObject subtype"
msgstr "'%s::%s' жарамды қасиет атауы емес; '%s' GObject ішкі түрі емес"

#: ../shared/nm-utils/nm-shared-utils.c:295
#, c-format
msgid "unable to set property '%s' of type '%s' from value of type '%s'"
msgstr "'%s' түріндегі мәннен '%s' түріндегі '%s' қасиетін орнату мүмкін емес"

#: ../shared/nm-utils/nm-shared-utils.c:306
#, c-format
msgid "value \"%s\" of type '%s' is invalid or out of range for property '%s' of type '%s'"
msgstr "«%s» мәні ('%s' түрі) '%s' қасиеті үшін (түрі '%s') жарамсыз немесе ауқымнан тыс"

#: ../shared/nm-utils/nm-vpn-plugin-utils.c:69
#, c-format
msgid "unable to get editor plugin name: %s"
msgstr "түзетуші плагинінің атауын алу мүмкін емес: %s"

#: ../shared/nm-utils/nm-vpn-plugin-utils.c:103
#, c-format
msgid "missing plugin file \"%s\""
msgstr "«%s» плагин файлы жоқ"

#: ../shared/nm-utils/nm-vpn-plugin-utils.c:109
#, c-format
msgid "cannot load editor plugin: %s"
msgstr "түзетуші плагинін жүктеу мүмкін емес: %s"

#: ../shared/nm-utils/nm-vpn-plugin-utils.c:118
#, c-format
msgid "cannot load factory %s from plugin: %s"
msgstr "плагиннен %s фабрикасын жүктеу мүмкін емес: %s"

#: ../shared/nm-utils/nm-vpn-plugin-utils.c:144
msgid "unknown error creating editor instance"
msgstr "түзетуші инстанциясын жасау кезіндегі белгісіз қате"
